{
  "name": "amplify-vite-react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-amplify-outputs.js && vite --mode development",
    "prod": "node scripts/copy-amplify-outputs.js && vite --mode production",
    "build": "node scripts/copy-amplify-outputs.js && tsc && vite build --mode production",
    "build:dev": "node scripts/copy-amplify-outputs.js && tsc && vite build --mode development",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.5.5",
    "@googlemaps/js-api-loader": "^2.0.2",
    "aws-amplify": "^6.6.6",
    "aws-jwt-verify": "^4.0.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.65.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^29.1.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vite": "^5.4.10",
    "vitest": "^4.1.9"
  }
}
